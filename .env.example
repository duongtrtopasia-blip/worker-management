# ===== CẤU HÌNH CƠ BẢN =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== CẤU HÌNH TELEGRAM BOT =====
# 1. Tạo Bot qua @BotFather trên Telegram để lấy Token này
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ

# 2. Lấy Chat ID của bạn (hoặc group quản lý) bằng cách chat với @userinfobot hoặc thêm bot @RawDataBot vào nhóm
# Nếu là group, Chat ID thường có dấu âm phía trước (VD: -100123456789)
TELEGRAM_CHAT_ID=123456789

# ===== CẤU HÌNH SUPABASE =====
# Lấy URL và ANON KEY trong phần Project Settings > API của Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5c...

